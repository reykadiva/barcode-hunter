# Legacy v1 database used by quarantined routes during Sprint 0 migration.
DATABASE_URL="postgresql://user:password@localhost:5432/scan_chan_legacy"

# Scan Chan v2 database boundaries. Guest and Arashu data must remain isolated.
GUEST_DATABASE_URL="postgresql://user:password@localhost:5432/scan_chan_guest"
ARASHU_DATABASE_URL="postgresql://user:password@localhost:5432/scan_chan_arashu"

# Supabase configuration for Arashu auth and legacy upload support.
NEXT_PUBLIC_SUPABASE_URL="https://example.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-anon-key"
SUPABASE_SERVICE_ROLE_KEY="replace-with-service-role-key"
